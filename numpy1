        "import numpy as np\n",
        "marks = np.random.randint(30, 101, size=(10, 5))\n",
        "print(\"Student Marks (10 Students × 5 Subjects):\")\n",
        "print(marks)\n",
        "total_marks = marks.sum(axis=1)\n",
        "average_marks = marks.mean(axis=1)\n",
        "\n",
        "print(\"\\nTotal Marks of Each Student:\")\n",
        "print(total_marks)\n",
        "print(\"\\nAverage Marks of Each Student:\")\n",
        "print(average_marks)\n",
        "highest_index = np.argmax(total_marks)\n",
        "lowest_index = np.argmin(total_marks)\n",
        "print(\"Student Index:\", highest_index)\n",
        "print(\"Total Marks:\", total_marks[highest_index])\n",
        "\n",
        "print(\"\\nStudent with Lowest Total Marks:\")\n",
        "print(\"Student Index:\", lowest_index)\n",
        "print(\"Total Marks:\", total_marks[lowest_index])\n",
        "class_mean = marks.mean()\n",
        "class_std = marks.std()\n",
        "\n",
        "print(\"\\nOverall Class Mean:\", class_mean)\n",
        "print(\"Overall Class Standard Deviation:\", class_std)\n",
        "sorted_indices = np.argsort(total_marks)[::-1]\n",
